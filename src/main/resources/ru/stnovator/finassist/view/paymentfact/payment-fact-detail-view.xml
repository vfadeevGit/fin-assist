<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<view xmlns="http://jmix.io/schema/flowui/view"
      title="msg://ru.stnovator.finassist.view.paymentfact/PaymentFactDetailView.title"
      focusComponent="form">
    <data>
        <instance id="paymentFactDc"
                  class="ru.stnovator.finassist.entity.PaymentFact">
            <fetchPlan extends="_base">
                <property fetchPlan="_base" name="contract">
                    <property fetchPlan="_base" name="customer"/>
                </property>
                <property fetchPlan="_base" name="project"/>
            </fetchPlan>
            <loader/>
        </instance>
        <collection id="customersDc"
                    class="ru.stnovator.finassist.entity.Customer">
            <fetchPlan extends="_base"/>
            <loader id="customersDl" readOnly="true">
                <query>
                    <![CDATA[select e from Customer e order by e.name]]>
                </query>
            </loader>
        </collection>
        <collection id="contractsDc"
                    class="ru.stnovator.finassist.entity.Contract">
            <fetchPlan extends="_base">
                <property fetchPlan="_base" name="customer"/>
            </fetchPlan>
            <loader id="contractsDl" readOnly="true">
                <query>
                    <![CDATA[select e from Contract e where e.customer = :customer order by e.internalID]]>
                </query>
            </loader>
        </collection>
        <collection id="projectsDc"
                    class="ru.stnovator.finassist.entity.Project">
            <fetchPlan extends="_base">
                <property fetchPlan="_base" name="contract"/>
            </fetchPlan>
            <loader id="projectsDl" readOnly="true">
                <query>
                    <![CDATA[select e from Project e where e.contract = :contract order by e.name]]>
                </query>
            </loader>
        </collection>
    </data>
    <actions>
        <action id="saveAction" type="detail_saveClose"/>
        <action id="closeAction" type="detail_close"/>
    </actions>
    <facets>
        <dataLoadCoordinator auto="true"/>
    </facets>
    <layout>
        <formLayout id="form" dataContainer="paymentFactDc">
            <entityPicker id="customersPicker"
                          label="msg://ru.stnovator.finassist.view.paymentfact/PaymentFactDetailView.customer"
                          metaClass="Customer"
                          dataContainer="contractsDc" property="customer">
                <actions>
                    <action id="lookupAction" type="entity_lookup"/>
                    <action id="openAction" type="entity_open"/>
                    <action id="customerClearAction" type="entity_clear"/>
                </actions>
            </entityPicker>
            <entityComboBox id="contractField"
                            property="contract"
                            label="msg://ru.stnovator.finassist.view.paymentfact/PaymentFactDetailView.contract"
                            itemsContainer="contractsDc">
                <actions>
                    <action id="contractClearAction" type="entity_clear"/>
                </actions>
            </entityComboBox>
            <entityComboBox id="projectField"
                            property="project"
                            label="msg://ru.stnovator.finassist.view.paymentfact/PaymentFactDetailView.project"
                            itemsContainer="projectsDc">
                <actions>
                    <action id="projectClearAction" type="entity_clear"/>
                </actions>
            </entityComboBox>
            <datePicker id="paymentDateField" property="paymentDate"/>
            <textField id="amountField" property="amount"/>
        </formLayout>
        <hbox id="detailActions">
            <button id="saveAndCloseBtn" action="saveAction"/>
            <button id="closeBtn" action="closeAction"/>
        </hbox>
    </layout>
</view>
