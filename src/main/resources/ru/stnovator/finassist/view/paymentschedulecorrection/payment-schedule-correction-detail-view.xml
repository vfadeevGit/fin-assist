<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<view xmlns="http://jmix.io/schema/flowui/view"
      title="msg://ru.stnovator.finassist.view.paymentschedulecorrection/PaymentScheduleCorrectionDetailView.title"
      focusComponent="form">
    <data>
        <instance id="paymentScheduleCorrectionDc"
                  class="ru.stnovator.finassist.entity.PaymentScheduleCorrection">
            <fetchPlan>
                <property name="createdDate"/>
                <property name="lastModifiedDate"/>
                <property name="addendum">
                    <property name="contract">
                        <property name="customer"/>
                    </property>
                </property>
                <property name="project">
                    <property name="contract">
                        <property name="customer"/>
                    </property>
                </property>
                <property name="items">
                    <property name="correction" fetchPlan="_base"/>
                </property>
            </fetchPlan>
            <loader/>
            <collection id="paymentScheduleCorrectionItemsDc" property="items"/>
        </instance>
    </data>
    <actions>
        <action id="saveAction" type="detail_saveClose"/>
        <action id="closeAction" type="detail_close"/>
    </actions>
    <facets>
        <dataLoadCoordinator auto="true"/>
    </facets>
    <layout>
        <formLayout id="form" dataContainer="paymentScheduleCorrectionDc">
            <entityPicker id="addendumField"
                          property="addendum"
                          label="msg://ru.stnovator.finassist.view.paymentschedulecorrection/PaymentScheduleCorrectionDetailView.addendum">
                <actions>
                    <action id="openAction" type="entity_open"/>
                    <action id="lookupAction" type="entity_lookup"/>
                    <action id="clearAction" type="value_clear"/>
                </actions>
            </entityPicker>
            <entityPicker id="projectField"
                          property="project"
                          label="msg://ru.stnovator.finassist.view.paymentschedulecorrection/PaymentScheduleCorrectionDetailView.project">
                <actions>
                    <action id="openAction_1" type="entity_open"/>
                    <action id="lookupAction_1" type="entity_lookup"/>
                    <action id="clearAction_1" type="value_clear"/>
                </actions>
            </entityPicker>
            <entityPicker id="contractField"
                          property="project.contract"
                          label="msg://ru.stnovator.finassist.view.paymentschedulecorrection/PaymentScheduleCorrectionDetailView.contract"
                          readOnly="true"/>
            <entityPicker id="customerField"
                          property="project.contract.customer"
                          label="msg://ru.stnovator.finassist.view.paymentschedulecorrection/PaymentScheduleCorrectionDetailView.customer"
                          readOnly="true"/>
            <dateTimePicker id="createdDateField"
                            property="createdDate"
                            label="msg://ru.stnovator.finassist.view.paymentschedulecorrection/PaymentScheduleCorrectionDetailView.createdDate"
                            readOnly="true"/>
            <dateTimePicker id="lastModifiedDateField"
                            property="lastModifiedDate"
                            label="msg://ru.stnovator.finassist.view.paymentschedulecorrection/PaymentScheduleCorrectionDetailView.lastModifiedDate"
                            readOnly="true"/>
        </formLayout>
        <h4 text="msg://ru.stnovator.finassist.view.paymentschedulecorrection/PaymentScheduleCorrectionDetailView.items"/>
        <hbox id="itemsButtonsPanel" classNames="buttons-panel">
            <button id="createItemBtn" action="paymentScheduleCorrectionItemsDataGrid.create"/>
            <button id="editItemBtn" action="paymentScheduleCorrectionItemsDataGrid.edit"/>
            <button id="removeItemBtn" action="paymentScheduleCorrectionItemsDataGrid.remove"/>
        </hbox>
        <dataGrid id="paymentScheduleCorrectionItemsDataGrid"
                  dataContainer="paymentScheduleCorrectionItemsDc"
                  width="100%"
                  minHeight="16em">
            <actions>
                <action id="create" type="list_create">
                    <properties>
                        <property name="openMode" value="DIALOG"/>
                        <property name="viewId" value="PaymentScheduleCorrectionItem.detail"/>
                    </properties>
                </action>
                <action id="edit" type="list_edit">
                    <properties>
                        <property name="openMode" value="DIALOG"/>
                        <property name="viewId" value="PaymentScheduleCorrectionItem.detail"/>
                    </properties>
                </action>
                <action id="remove" type="list_remove"/>
            </actions>
            <columns>
                <column property="itemDate"
                        header="msg://ru.stnovator.finassist.view.paymentschedulecorrection/columnCorrectionDate.header"/>
                <column property="amount"
                        header="msg://ru.stnovator.finassist.view.paymentschedulecorrection/columnCorrectionAmount.header"/>
            </columns>
        </dataGrid>
        <hbox id="detailActions">
            <button id="saveAndCloseBtn" action="saveAction"/>
            <button id="closeBtn" action="closeAction"/>
        </hbox>
    </layout>
</view>
